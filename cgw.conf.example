# cgw.conf.example — All configuration options for claude-git-workflow
#
# Copy to .cgw.conf in your project root, or run:
#   ./scripts/git/configure.sh
# to auto-generate it from project scanning.
#
# .cgw.conf is git-ignored by default (configure.sh adds it to .gitignore).
# Priority: environment variables > .cgw.conf > built-in defaults

# ============================================================================
# BRANCH NAMES
# ============================================================================

# Source branch — where development happens; merged into target
# Default: development
CGW_SOURCE_BRANCH="development"

# Target branch — stable/production branch; receives merges
# Default: main
CGW_TARGET_BRANCH="main"

# ============================================================================
# LOCAL-ONLY FILES
# ============================================================================
# Space-separated list of files/directories that must NEVER be committed.
# Entries ending with / are treated as directory prefixes.
# commit_enhanced.sh will auto-unstage these before committing.
# configure.sh also bakes this list into the pre-commit hook.
#
# Default: CLAUDE.md MEMORY.md .claude/ logs/
# (configure.sh auto-detects project-specific additions like .env files)

CGW_LOCAL_FILES="CLAUDE.md MEMORY.md .claude/ logs/"

# ============================================================================
# COMMIT MESSAGE PREFIXES
# ============================================================================
# Standard conventional commit prefixes are always included:
#   feat fix docs chore test refactor style perf
#
# Add project-specific extras here (pipe-separated):
# CGW_EXTRA_PREFIXES="cuda|tensorrt"    # GPU/ML project
# CGW_EXTRA_PREFIXES="android|ios"      # Mobile project
# CGW_EXTRA_PREFIXES="infra|deploy"     # DevOps project

CGW_EXTRA_PREFIXES=""

# ============================================================================
# LINT CONFIGURATION
# ============================================================================
# Set CGW_LINT_CMD="" to disable lint checks entirely.
#
# ── Python / ruff (default) ──────────────────────────────
CGW_LINT_CMD="ruff"
CGW_LINT_CHECK_ARGS="check ."
CGW_LINT_FIX_ARGS="check --fix ."
CGW_LINT_EXCLUDES="--extend-exclude logs --extend-exclude .venv"
CGW_FORMAT_CMD="ruff"
CGW_FORMAT_CHECK_ARGS="format --check ."
CGW_FORMAT_FIX_ARGS="format ."
CGW_FORMAT_EXCLUDES="--exclude logs --exclude .venv"
#
# ── JavaScript / ESLint + Prettier ──────────────────────
# CGW_LINT_CMD="eslint"
# CGW_LINT_CHECK_ARGS="."
# CGW_LINT_FIX_ARGS=". --fix"
# CGW_LINT_EXCLUDES=""
# CGW_FORMAT_CMD="prettier"
# CGW_FORMAT_CHECK_ARGS="--check ."
# CGW_FORMAT_FIX_ARGS="--write ."
# CGW_FORMAT_EXCLUDES=""
#
# ── Go / golangci-lint ───────────────────────────────────
# CGW_LINT_CMD="golangci-lint"
# CGW_LINT_CHECK_ARGS="run"
# CGW_LINT_FIX_ARGS="run --fix"
# CGW_LINT_EXCLUDES=""
# CGW_FORMAT_CMD="gofmt"
# CGW_FORMAT_CHECK_ARGS="-l ."
# CGW_FORMAT_FIX_ARGS="-w ."
# CGW_FORMAT_EXCLUDES=""
#
# ── No linter ───────────────────────────────────────────
# CGW_LINT_CMD=""
# CGW_FORMAT_CMD=""

# ============================================================================
# DOCS CI VALIDATION (merge_with_validation.sh)
# ============================================================================
# Extended regex (bash ERE) matching allowed doc filenames in docs/.
# Empty string = skip docs validation entirely (default).
# Only needed if you have strict CI rules about what docs can land on target.
#
# Example:
# CGW_DOCS_PATTERN="^(README\.md|.*_GUIDE\.md|.*_REFERENCE\.md|CHANGELOG\.md)$"

CGW_DOCS_PATTERN=""

# ============================================================================
# DEV-ONLY FILE WARNINGS (cherry_pick_commits.sh)
# ============================================================================
# Space-separated paths. If a cherry-picked commit touches these files,
# you'll get a warning (or abort in non-interactive mode).
# Empty = no check (default).
#
# Example:
# CGW_DEV_ONLY_FILES="tests/ pytest.ini docs/TESTING_GUIDE.md"

CGW_DEV_ONLY_FILES=""

# ============================================================================
# TESTS DIRECTORY CLEANUP (merge_with_validation.sh)
# ============================================================================
# When 1: removes tests/ from target branch if "tests/" is in .gitignore.
# When 0: leaves tests/ alone (default — most projects want tests everywhere).

CGW_CLEANUP_TESTS="0"

# ============================================================================
# FORCE-PUSH PROTECTION (push_validated.sh)
# ============================================================================
# Space-separated branch names that require --force flag + manual confirmation
# for force-push. Defaults to CGW_TARGET_BRANCH if not set.

# CGW_PROTECTED_BRANCHES="main staging"
