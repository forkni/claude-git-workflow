# Force LF line endings for shell scripts (required for Linux/macOS compatibility)
*.sh text eol=lf
*.bats text eol=lf
*.bash text eol=lf
hooks/pre-commit text eol=lf

# Text files — normalize to LF
*.md text eol=lf
*.conf text eol=lf
*.example text eol=lf
*.gitignore text eol=lf
*.yml text eol=lf
LICENSE text eol=lf
